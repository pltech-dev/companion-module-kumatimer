{
	"name": "companion-module-pltech-kumatimer",
	"version": "1.7.27",
	"description": "Bitfocus Companion module for KUMA Timer (HTTP/JSON)",
	"type": "module",
	"main": "dist/main.js",
	"packageManager": "yarn@4.9.1",
	"engines": {
		"node": "^22.20",
		"yarn": "^4"
	},
	"scripts": {
		"build": "tsc",
		"build:watch": "tsc --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint src tests",
		"lint:fix": "eslint src tests --fix",
		"package": "yarn build && companion-module-build && node scripts/fix-manifest.mjs",
		"format": "prettier --write ."
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"dependencies": {
		"@companion-module/base": "~1.14.1"
	},
	"devDependencies": {
		"@companion-module/tools": "^2.6.1",
		"@types/node": "^22.19.17",
		"eslint": "^10.2.0",
		"prettier": "^3.8.1",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.58.0",
		"vitest": "^3.2.0"
	}
}
